{
  "distSpecVersion": "1.1.0",
  "storage": {
    "rootDirectory": "/var/lib/registry",
    "remoteCache": false,
    "storageDriver": {
      "name": "s3",
      "rootdirectory": "/registry",
      "region": "${SPACES_REGION}",
      "regionendpoint": "${SPACES_ENDPOINT}",
      "bucket": "platform-registry",
      "accesskey": "${SPACES_ACCESS_KEY}",
      "secretkey": "${SPACES_SECRET_KEY}",
      "secure": true,
      "skipverify": false
    }
  },
  "http": {
    "address": "0.0.0.0",
    "port": "5000",
    "auth": {
      "htpasswd": {
        "path": "/etc/zot/htpasswd"
      },
      "failDelay": 5
    },
    "accessControl": {
      "repositories": {
        "**": {
          "policies": [
            {
              "users": ["ci"],
              "actions": ["read", "create", "update", "delete"]
            },
            {
              "users": ["cluster"],
              "actions": ["read"]
            }
          ],
          "defaultPolicy": [],
          "anonymousPolicy": []
        }
      }
    }
  },
  "log": {
    "level": "info"
  },
  "extensions": {
    "search": {
      "enable": true,
      "cve": {
        "updateInterval": "24h"
      }
    },
    "scrub": {
      "enable": true,
      "interval": "24h"
    },
    "metrics": {
      "enable": true,
      "prometheus": {
        "path": "/metrics"
      }
    }
  }
}
