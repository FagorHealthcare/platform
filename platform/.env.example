# =====================================================================
# Platform stack — operator-supplied environment variables.
#
# Copy this file to `.env` on the droplet (it lives only on the droplet,
# is gitignored, and is loaded by docker-compose's env_file:).
#   cp .env.example .env
#   $EDITOR .env
#
# Reference: docs/migration/06-platform-tier.md, 02-registry.md, 03-logging.md
# =====================================================================

# ---------------------------------------------------------------------
# Caddy — Let's Encrypt registration email.
# Used for ACME account contact + expiry notifications.
# ---------------------------------------------------------------------
LETSENCRYPT_EMAIL=ops@fagorhealthcare.com

# ---------------------------------------------------------------------
# Zot — S3 backend (DigitalOcean Spaces).
#
# These point Zot's `s3` storage driver at the registry bucket.
# The credentials are a DO Spaces access key pair; generate them under
# DO console → API → Spaces Keys.
# ---------------------------------------------------------------------
SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
SPACES_REGION=fra1
SPACES_BUCKET_REGISTRY=md-platform-registry
SPACES_ACCESS_KEY=<DO Spaces access key>
SPACES_SECRET_KEY=<DO Spaces secret key>

# ---------------------------------------------------------------------
# Loki — S3 backend (DigitalOcean Spaces).
#
# Same Spaces account by default, different bucket. For least-privilege,
# operators may provision a SEPARATE Spaces key pair scoped to the
# platform-logs bucket only. The single-key shortcut is OK for v1 but
# worth tightening later (tracked as out-of-scope follow-up in pillar 06).
# ---------------------------------------------------------------------
LOKI_S3_BUCKET=md-platform-logs
LOKI_S3_REGION=fra1
LOKI_S3_ACCESS_KEY=<DO Spaces access key — same as above OR separate>
LOKI_S3_SECRET_KEY=<DO Spaces secret key — same as above OR separate>
