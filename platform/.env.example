# =====================================================================
# Platform stack — operator-supplied environment variables.
#
# Copy this file to `.env` on the droplet (it lives only on the droplet,
# is gitignored, and is loaded by docker-compose's env_file:).
#   cp .env.example .env
#   $EDITOR .env
#
# Reference: docs/migration/06-platform-tier.md, 02-registry.md, 03-logging.md
# =====================================================================

# ---------------------------------------------------------------------
# Caddy — Let's Encrypt registration email.
# Used for ACME account contact + expiry notifications.
# ---------------------------------------------------------------------
LETSENCRYPT_EMAIL=ops@fagorhealthcare.com

# ---------------------------------------------------------------------
# Zot — S3 backend (DigitalOcean Spaces).
#
# These point Zot's `s3` storage driver at the registry bucket.
# The credentials are a DO Spaces access key pair; generate them under
# DO console → API → Spaces Keys.
# ---------------------------------------------------------------------
SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
SPACES_REGION=fra1
SPACES_BUCKET_REGISTRY=md-platform-registry
SPACES_ACCESS_KEY=<DO Spaces access key>
SPACES_SECRET_KEY=<DO Spaces secret key>

# ---------------------------------------------------------------------
# Loki — S3 backend (DigitalOcean Spaces).
#
# Same Spaces account by default, different bucket. For least-privilege,
# operators may provision a SEPARATE Spaces key pair scoped to the
# platform-logs bucket only. The single-key shortcut is OK for v1 but
# worth tightening later (tracked as out-of-scope follow-up in pillar 06).
# ---------------------------------------------------------------------
LOKI_S3_BUCKET=md-platform-logs
LOKI_S3_REGION=fra1
LOKI_S3_ACCESS_KEY=<DO Spaces access key — same as above OR separate>
LOKI_S3_SECRET_KEY=<DO Spaces secret key — same as above OR separate>

# ---------------------------------------------------------------------
# oauth2-proxy — GitHub OAuth App "FMD Platform Observability".
#
# Cookie secret is generated by cloud-init (openssl rand -base64 32) and
# stored in /root/platform-credentials.txt. Client ID/Secret are pasted
# in manually from the OAuth App registration.
# ---------------------------------------------------------------------
OAUTH2_CLIENT_ID=<GitHub OAuth App client ID>
OAUTH2_CLIENT_SECRET=<GitHub OAuth App client secret>
OAUTH2_COOKIE_SECRET=<32-byte base64; openssl rand -base64 32>

# ---------------------------------------------------------------------
# Dex — OIDC broker for Zot's browser login.
#
# Uses a SEPARATE GitHub OAuth App from oauth2-proxy ("FMD Dex"), with
# callback URI:
#   https://dex.platform.fmd.fagorhealthcare.com/callback
#
# The Zot↔Dex shared secret is generated once by cloud-init (openssl
# rand -hex 32). Rotating it requires a coordinated restart of both
# dex and zot — both consume it.
# ---------------------------------------------------------------------
DEX_GITHUB_CLIENT_ID=<GitHub OAuth App "FMD Dex" client ID>
DEX_GITHUB_CLIENT_SECRET=<GitHub OAuth App "FMD Dex" client secret>
DEX_ZOT_CLIENT_SECRET=<random 32-byte hex; openssl rand -hex 32>

# ---------------------------------------------------------------------
# Zot accessControl — group slugs from GitHub teams.
#
# Dex emits team membership in the OIDC `groups` claim as
# "FagorHealthcare:<team-slug>" strings (teamNameField: slug in
# platform/dex/config.yaml.tmpl). These two variables select which
# teams get read+write and read-only on the registry.
#
# To list candidate slugs:
#   gh api orgs/FagorHealthcare/teams --jq '.[].slug'
# ---------------------------------------------------------------------
ZOT_RW_GROUP=FagorHealthcare:platform
ZOT_RO_GROUP=FagorHealthcare:cluster-pull
