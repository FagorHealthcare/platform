# =====================================================================
# Caddy — TLS edge for the platform droplet.
#
# Two virtual hosts under *.platform.fmd.fagorhealthcare.com, both with
# automatic HTTPS via Let's Encrypt (HTTP-01 challenge over port 80).
#
# In a future migration we may switch to a DNS-01 challenge using the
# DigitalOcean API (would let us hide ports 80/443 behind the cloud
# firewall). For now HTTP-01 is fine: 80/443 are explicitly open in
# the terraform-managed firewall and DNS already points at the
# reserved IP.
#
# Reference: docs/migration/06-platform-tier.md
# =====================================================================

{
    email {$LETSENCRYPT_EMAIL}
    # Default global options:
    #   - ACME directory: Let's Encrypt production
    #   - HTTP-01 challenge on :80
    #   - admin API on :2019 (internal, used by healthcheck)
}

# =====================================================================
# Snippets: auth gate via oauth2-proxy
# =====================================================================
#
# `oauth2_gate` is invoked from the operator-facing vhosts to require
# a valid GitHub session. It does two things:
#
#   1. Exposes /oauth2/* (start, callback, sign_in, sign_out) on the
#      vhost by reverse-proxying to oauth2-proxy:4180. Without this
#      the login flow doesn't work end-to-end.
#
#   2. Gates everything else via forward_auth → /oauth2/auth. On 200
#      Caddy proceeds; on 401 it redirects the browser to /oauth2/start
#      (which then redirects to GitHub).
#
# Cookie scope is `.platform.fmd.fagorhealthcare.com` so a single login
# covers the apex AND every subdomain (logs, alerts, dashboards). SSO.
#
# Usage at the top of any vhost:
#     import oauth2_gate
# ---------------------------------------------------------------------
(oauth2_gate) {
    # Public endpoints used by the login flow itself.
    handle /oauth2/* {
        reverse_proxy oauth2-proxy:4180 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-Uri {uri}
        }
    }

    # Catch-all gate. Every request that didn't match /oauth2/* must
    # have a valid session cookie or it gets bounced to login. The
    # vhosts that need a public exception (e.g. apex /healthz) declare
    # an explicit `handle /healthz { ... }` BEFORE importing this
    # snippet AND wrap their own forward_auth with a matcher (see the
    # apex vhost below). Named matchers don't survive being defined
    # inside a snippet and referenced from the importing site, so we
    # keep the snippet plain.
    forward_auth oauth2-proxy:4180 {
        uri /oauth2/auth
        copy_headers X-Auth-Request-User X-Auth-Request-Email X-Auth-Request-Preferred-Username

        # 401 → kick the browser into the login flow. Without this
        # users see a raw 401 page instead of the GitHub OAuth screen.
        @unauth status 401
        handle_response @unauth {
            redir * /oauth2/start?rd={scheme}://{host}{uri}
        }
    }
}

# ---------------------------------------------------------------------
# platform.fmd.fagorhealthcare.com → Portal (apex)
#
# Single entrypoint for operators. Serves a static landing page that
# polls health endpoints of:
#   - the cluster (md-core/md-auth/md-resi-back/md-resi-front) via
#     /api/cluster/health/<svc>, which Caddy proxies to the cluster's
#     own ingress-health (no auth there — it's already public).
#   - the platform services (loki/alertmanager/perses/zot) via
#     /api/platform/health/<svc>, resolved locally on this droplet.
#   - Alertmanager active alerts via /api/am/active.
#
# All gated behind oauth2-proxy via the `oauth2_gate` snippet above.
# The /oauth2/* paths are public so the login flow can complete.
# ---------------------------------------------------------------------
platform.fmd.fagorhealthcare.com {
    # Caddy's default directive ordering puts `forward_auth` ahead of
    # `handle`, which means a catch-all forward_auth would intercept
    # /healthz and /oauth2/* before their handlers had a chance.
    # Named matchers (`forward_auth @x`) silently produced empty
    # matchers in v2.10 — couldn't make them work either.
    #
    # `route` blocks bypass directive ordering and execute everything
    # inside in strict declaration order. Public paths are declared
    # first, the auth gate sits in the middle, and authenticated paths
    # come after — so /healthz and /oauth2/* never reach forward_auth.
    route {
        # --- Public probe ---
        handle /healthz {
            respond "ok" 200
        }

        # --- Login flow (must be public) ---
        handle /oauth2/* {
            reverse_proxy oauth2-proxy:4180 {
                header_up X-Real-IP {remote_host}
                header_up X-Forwarded-Uri {uri}
            }
        }

        # --- Everything below requires a valid session ---
        forward_auth oauth2-proxy:4180 {
            uri /oauth2/auth
            copy_headers X-Auth-Request-User X-Auth-Request-Email X-Auth-Request-Preferred-Username

            @unauth status 401
            handle_response @unauth {
                redir * /oauth2/start?rd={scheme}://{host}{uri}
            }
        }

        # --- Cluster health proxies ---
        # The k8s ingress-health rule exposes /health/<svc> on
        # fmd.fagorhealthcare.com — same source of truth that
        # md-resi-front's status.html already uses. We proxy through
        # Caddy to keep everything same-origin (no CORS).
        handle /api/cluster/health/* {
            uri strip_prefix /api/cluster
            reverse_proxy https://fmd.fagorhealthcare.com {
                header_up Host fmd.fagorhealthcare.com
            }
        }

        # --- Platform health proxies (this droplet) ---
        handle /api/platform/health/loki {
            reverse_proxy loki:3100 {
                rewrite /ready
            }
        }
        handle /api/platform/health/alertmanager {
            reverse_proxy alertmanager:9093 {
                rewrite /-/ready
            }
        }
        handle /api/platform/health/perses {
            reverse_proxy perses:8080 {
                rewrite /api/v1/projects
            }
        }
        handle /api/platform/health/zot {
            reverse_proxy zot:5000 {
                rewrite /v2/
            }
        }

        # --- Active alerts ---
        handle /api/am/active {
            reverse_proxy alertmanager:9093 {
                rewrite /api/v2/alerts?active=true&silenced=false&inhibited=false
            }
        }

        # --- Landing page (static) ---
        handle {
            root * /srv/landing
            file_server
        }
    }

    encode gzip

    log {
        output stdout
        format json
    }
}

# ---------------------------------------------------------------------
# registry.platform.fmd.fagorhealthcare.com → Zot
#
# NOTE: Zot stays on its OWN basic_auth (configured in zot/config.json),
# not on oauth2-proxy. OCI clients (docker, oras, crane) speak HTTP
# basic auth via WWW-Authenticate negotiation; they don't follow the
# browser OAuth dance. Forcing oauth2-proxy here would break every
# `docker pull` from the cluster nodes.
#
# OCI clients also require the original Host header to pass through
# unchanged so Zot can issue correct redirects/links.
# ---------------------------------------------------------------------
registry.platform.fmd.fagorhealthcare.com {
    reverse_proxy zot:5000 {
        header_up Host {host}
    }

    encode gzip

    log {
        output stdout
        format json
    }
}

# ---------------------------------------------------------------------
# logs.platform.fmd.fagorhealthcare.com → Loki
#
# Vector pushes log batches to /loki/api/v1/push as authenticated POSTs
# (basic auth). LogQL clients (logcli, Grafana) hit /loki/api/v1/query*.
# Loki itself runs with auth_enabled: false; auth is enforced ONLY at
# this edge.
#
# Credentials are generated by cloud-init and exported into .env as:
#   LOKI_AUTH_USER=<random>
#   LOKI_AUTH_HASH=<bcrypt of the random password>
# Cleartext is in /root/platform-credentials.txt on the droplet.
# ---------------------------------------------------------------------
logs.platform.fmd.fagorhealthcare.com {
    # ---------- vector push path: keep basic_auth ----------
    # Vector running in the k8s cluster pushes log batches to
    # /loki/api/v1/push. It speaks HTTP basic auth, NOT OAuth2.
    # Treating this path specially lets human operators use OAuth
    # for the rest (LogQL queries, labels API, the Grafana-style
    # UI) without breaking the ingest pipeline.
    @vector_push path /loki/api/v1/push
    handle @vector_push {
        basic_auth {
            {$LOKI_AUTH_USER} {$LOKI_AUTH_HASH}
        }
        reverse_proxy loki:3100
    }

    # ---------- everything else: operator-facing, OAuth gated ----------
    handle {
        import oauth2_gate
        reverse_proxy loki:3100
    }

    encode gzip

    log {
        output stdout
        format json
    }
}

# ---------------------------------------------------------------------
# alerts.platform.fmd.fagorhealthcare.com → Alertmanager UI
# Same basic-auth credential pair as Loki — the Alertmanager UI is
# operator-facing only.
# ---------------------------------------------------------------------
alerts.platform.fmd.fagorhealthcare.com {
    import oauth2_gate

    reverse_proxy alertmanager:9093

    encode gzip

    log {
        output stdout
        format json
    }
}

# ---------------------------------------------------------------------
# dashboards.platform.fmd.fagorhealthcare.com → Perses UI
# Same basic-auth credential pair. Perses itself runs with auth
# disabled (single-user view); the gate is at the edge.
# ---------------------------------------------------------------------
dashboards.platform.fmd.fagorhealthcare.com {
    import oauth2_gate

    reverse_proxy perses:8080

    encode gzip

    log {
        output stdout
        format json
    }
}
